{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"extends": ["./biome.json"],
	"root": false,
	"css": {
		"parser": {
			"allowWrongLineComments": false,
			"tailwindDirectives": true
		},
		"formatter": {
			"enabled": true,
			"quoteStyle": "double"
		}
	},
	"overrides": [
		{
			"includes": ["*.astro"],
			"linter": {
				"enabled": true,
				"rules": {
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					},
					"style": {
						"useConst": "off",
						"useImportType": "off"
					}
				}
			},
			"formatter": {
				"indentWidth": 2,
				"bracketSpacing": true
			}
		}
	]
}
